# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables
.env
.env.local
*.env

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp
*.swo

# Data / large files
data/records/*.json
data/sources/*.json
data/flags/*.json
data/flags/rejected/*.json
# Keep gitignored data dirs tracked via .gitkeep
!data/records/.gitkeep
!data/sources/.gitkeep
!data/flags/.gitkeep
!data/flags/rejected/.gitkeep

# Downloaded image cache
data/images/

# Obsidian app files (keep notes, ignore app config)
obsidian/.obsidian/
obsidian/.trash/

# Logs
*.log
logs/

# Test artifacts
.pytest_cache/
htmlcov/
.coverage
