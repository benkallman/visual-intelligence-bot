# ============================================================
# visual-intelligence-bot — environment configuration
# Copy this file to .env and fill in the values you need.
# .env is gitignored. Never commit real keys.
# ============================================================


# ------------------------------------------------------------
# PROVIDER SELECTION
# ------------------------------------------------------------
# Comma-separated list of providers in priority order.
# Each provider is tried in sequence; if one fails or has no
# credentials, the next is used. Unknown names are skipped.
#
# Supported values: anthropic, openai, xai, ollama
# Default (if unset): anthropic,openai,xai,ollama
#
# PROVIDER_FALLBACK_ORDER=anthropic,openai,xai,ollama


# ------------------------------------------------------------
# ANTHROPIC / CLAUDE
# ------------------------------------------------------------
# Required to use Anthropic. Get a key at console.anthropic.com.
#
# ANTHROPIC_API_KEY=sk-ant-...

# Model override. Default: claude-sonnet-4-6
# ANTHROPIC_MODEL=claude-sonnet-4-6


# ------------------------------------------------------------
# OPENAI / GPT
# ------------------------------------------------------------
# Required to use OpenAI. Get a key at platform.openai.com.
# Also requires the openai package (included in requirements.txt).
#
# OPENAI_API_KEY=sk-...

# Model override. Default: gpt-4o
# OPENAI_MODEL=gpt-4o


# ------------------------------------------------------------
# xAI / GROK
# ------------------------------------------------------------
# Required to use xAI. Get a key at console.x.ai.
# Uses the OpenAI-compatible endpoint at api.x.ai/v1.
# Also requires the openai package (included in requirements.txt).
#
# XAI_API_KEY=xai-...

# Model override. Default: grok-2-vision-1212
# XAI_MODEL=grok-2-vision-1212


# ------------------------------------------------------------
# OLLAMA (local)
# ------------------------------------------------------------
# No API key required. Ollama must be running locally.
# Install: https://ollama.com — then: ollama pull llava
#
# Make Ollama the only provider for local nightly runs.
PROVIDER_FALLBACK_ORDER=ollama

# Base URL. Default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# Model override. Must be a vision-capable model.
OLLAMA_MODEL=llava:latest

# Max image dimension passed to Ollama after local preprocessing. Default: 512.
OLLAMA_MAX_IMAGE_SIZE=512

# Read timeout for image inference requests, in seconds. Default: 600.
# Increase on slow hardware; image inference via llava can take several minutes.
OLLAMA_IMAGE_TIMEOUT=600

# Read timeout for text-only requests (rarity scorer, pass2, recurrence). Default: 300.
OLLAMA_TEXT_TIMEOUT=300

# Local path to the visual-intelligence-archive repo used as a live knowledge source.
VISUAL_ARCHIVE_PATH=C:/visual-intelligence-archive


# ------------------------------------------------------------
# CONTINUOUS INGESTION
# ------------------------------------------------------------
# Sleep interval between partial nightly cycles, in seconds. Default: 1800.
CONTINUOUS_INTERVAL_SECONDS=1800


# ------------------------------------------------------------
# TELEGRAM OUTPUT (optional)
# ------------------------------------------------------------
# If TELEGRAM_ENABLED is not "true", Telegram is fully skipped.
# Items below rarity threshold or rejected by safety gate are never sent.
#
# TELEGRAM_ENABLED=false
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHANNEL_ID=@yourchannel
# TELEGRAM_MIN_RARITY_SCORE=0.6
